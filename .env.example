# Tauri 2 environment
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
TAURI_APPLE_CERTIFICATE=
TAURI_APPLE_CERTIFICATE_PASSWORD=
TAURI_APPLE_ID=
TAURI_APPLE_PASSWORD=
TAURI_APPLE_TEAM_ID=

# Sigstore / cosign (for release signing)
COSIGN_PRIVATE_KEY=
COSIGN_PASSWORD=

# Cloud upload providers (for testing — never commit real values)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# Telemetry endpoints (must remain empty for privacy)
BETTER_SHOT_TELEMETRY=
SENTRY_DSN=

# Dev / build
RUST_LOG=info,better_shot_core=debug
RUST_BACKTRACE=1
